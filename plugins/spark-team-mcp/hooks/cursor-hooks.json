{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/scripts/on_session_start_cursor.sh",
        "matcher": "startup|resume"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/scripts/on_user_prompt_cursor.sh",
        "timeout": 8
      }
    ],
    "stop": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/scripts/on_stop_cursor.sh",
        "timeout": 15,
        "loop_limit": 2
      }
    ]
  }
}
